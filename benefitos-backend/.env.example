# =====================================================
# Benifitos Backend Environment Configuration
# =====================================================

# -------------------------
# Server
# -------------------------
NODE_ENV=development
PORT=5001

# -------------------------
# Neo4j AuraDB
# -------------------------
# Local Development
NEO4J_URI=bolt://localhost:7687

# Example AuraDB:
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io

NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# -------------------------
# Authentication
# -------------------------
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# -------------------------
# Sarvam AI
# -------------------------
SARVAM_API_KEY=your_sarvam_api_key

# -------------------------
# Frontend URL
# -------------------------
CLIENT_URL=http://localhost:8081

# -------------------------
# CORS
# -------------------------
CORS_ORIGIN=http://localhost:8081

# -------------------------
# Render Workflows
# -------------------------
RENDER_API_KEY=
RENDER_SERVICE_ID=
RENDER_WORKFLOW_ID=

# -------------------------
# Logging
# -------------------------
LOG_LEVEL=info

# -------------------------
# Feature Flags
# -------------------------
ENABLE_NOTIFICATIONS=true
ENABLE_GRAPH_VISUALIZER=true
ENABLE_SARVAM_AI=true
ENABLE_RENDER_WORKFLOWS=true

# -------------------------
# Rate Limiting
# -------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100